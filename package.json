{
  "name": "btc-connect",
  "version": "0.5.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "dev": "bun run --filter './packages/*' dev",
    "test": "bun test",
    "lint": "bun run --filter './packages/*' lint",
    "format": "bun run --filter './packages/*' format",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "install:all": "bun install && bun run build",
    "version:patch": "./scripts/update-version.sh patch",
    "version:minor": "./scripts/update-version.sh minor",
    "version:major": "./scripts/update-version.sh major",
    "version:patch:push": "./scripts/update-version.sh patch --push",
    "version:minor:push": "./scripts/update-version.sh minor --push",
    "version:major:push": "./scripts/update-version.sh major --push"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/node": "^20.0.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^27.1.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@biomejs/biome": "^2.1.3"
  }
}
